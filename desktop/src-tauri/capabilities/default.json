{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities for the spreadsheet-agent main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-set-title",
    "core:event:allow-emit",
    "core:event:allow-listen",
    "core:path:default",
    "core:webview:allow-internal-toggle-devtools",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-read-file",
    "shell:default",
    "shell:allow-open"
  ]
}
