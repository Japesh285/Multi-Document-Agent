{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Spreadsheet Agent",
  "version": "0.1.0",
  "identifier": "com.spreadsheet.agent",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Spreadsheet Agent",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 680,
        "decorations": true,
        "transparent": false,
        "dragDropEnabled": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri:; img-src 'self' tauri: asset: http://localhost:8765 data: blob:; connect-src 'self' http://localhost:8765 ws://localhost:8765 http://localhost:11434; style-src 'self' 'unsafe-inline'; script-src 'self'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "category": "Productivity",
    "shortDescription": "Local-first autonomous spreadsheet intelligence",
    "longDescription": "Conversational spreadsheet analysis, web verification, Excel mutation, charts and reports — fully local, powered by Ollama.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": ["nsis", "msi"],
    "resources": [
      "../../*.py",
      "../../core/**/*.py",
      "../../loaders/**/*.py",
      "../../requirements.txt"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine",
        "displayLanguageSelector": false
      }
    }
  }
}
